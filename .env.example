# คัดลอกเป็น .env แล้วเติมค่าจริง — อย่า commit .env
#
# LINE Developers Console → Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ไปรษณีย์ไทย: Track & Trace API
THAIPOST_API_TOKEN=

# Supabase — ใช้เก็บรายการติดตามพัสดุ (เดิมเก็บเป็นไฟล์ JSON ที่หายตอน redeploy)
# หาได้ที่ Dashboard → Project Settings → API
#
# ⚠️ ต้องใช้ service_role ไม่ใช่ anon
#    service_role ข้าม RLS ได้ จึงใช้ได้เฉพาะฝั่งเซิร์ฟเวอร์
#    ห้ามเอาไปไว้ในโค้ดฝั่งเบราว์เซอร์เด็ดขาด ใครได้ไปคือเข้าถึงฐานข้อมูลได้ทั้งหมด
SUPABASE_URL=https://mowhbttcrnohkljbasxc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Render ตั้งให้เอง ไม่ต้องกรอก — ใช้ป้องกัน free tier หลับ
# RENDER_EXTERNAL_URL=

PORT=3000
